# Site
NEXT_PUBLIC_SITE_URL=https://example.com

# microCMS
MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key
MICROCMS_ACTIVITY_ENDPOINT=activities

# Contact Form
# NEXT_PUBLIC_ prefix means this value is exposed to the browser.
# Web3Forms access keys are designed for client-side use.
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-key

# Cloudflare Analytics (optional)
NEXT_PUBLIC_CF_ANALYTICS_TOKEN=your-cf-analytics-token

# Sentry (CI / server-side only)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
